          "name": "End-to-End Ledger Transactions",
          "item": [
            {
              "name": "Authorize Order",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Parse the incoming structural transaction payload response\r",
                      "const responseData = pm.response.json();\r",
                      "\r",
                      "// Confirm order creation layer is structurally valid\r",
                      "pm.test(\"Status code is 200 or 201\", function () {\r",
                      "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                      "});\r",
                      "\r",
                      "// Capture runtime transaction pipeline metrics safely\r",
                      "if (responseData && responseData.order) {\r",
                      "    if (responseData.order.id) {\r",
                      "        pm.environment.set(\"savedOrderId\", responseData.order.id);\r",
                      "        console.log(\"Captured Production Order ID Tracking Key:\", responseData.order.id);\r",
                      "    }\r",
                      "    \r",
                      "    // Track starting version matrix from server\r",
                      "    if (responseData.order.version !== undefined) {\r",
                      "        pm.environment.set(\"currentOrderVersion\", responseData.order.version);\r",
                      "        console.log(\"Synchronized Initial Database Version State:\", responseData.order.version);\r",
                      "    }\r",
                      "} else {\r",
                      "    console.warn(\"Execution Alert: Response payload missing structural order schema context.\");\r",
                      "}\r",
                      "pm.test(\"Response time is within acceptable threshold\", function () {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                      "});\r",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n  \"order\": {\r\n    \"location_id\": \"{{locationId}}\",\r\n    \"line_items\": [\r\n      {\r\n        \"name\": \"{{itemName}}\",\r\n        \"quantity\": \"1\",\r\n        \"base_price_money\": {\r\n          \"amount\": {{itemPrice}},\r\n          \"currency\": \"USD\"\r\n        }\r\n      }\r\n    ]\r\n  },\r\n  \"idempotency_key\": \"{{$guid}}\"\r\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "https://connect.squareupsandbox.com/v2/orders",
                  "protocol": "https",
                  "host": [
                    "connect",
                    "squareupsandbox",
                    "com"
                  ],
                  "path": [
                    "v2",
                    "orders"
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Fetch Order State",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Parse the server response payload\r",
                      "const responseData = pm.response.json();\r",
                      "\r",
                      "// Validate HTTP connectivity layer is active\r",
                      "pm.test(\"Status code is 200\", function () {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "// Multi-Format Schema Parsing\r",
                      "pm.test(\"Verify record state is OPEN\", function () {\r",
                      "    let orderData = null;\r",
                      "\r",
                      "    // Format 1: Server returns an array under the \"orders\" property\r",
                      "    if (responseData.orders && responseData.orders.length > 0) {\r",
                      "        orderData = responseData.orders[0];\r",
                      "    } \r",
                      "    // Format 2: Server returns a single object under the \"order\" property\r",
                      "    else if (responseData.order) {\r",
                      "        orderData = responseData.order;\r",
                      "    } \r",
                      "    // Format 3: Server returns the object directly at the root level\r",
                      "    else if (responseData && !responseData.errors) {\r",
                      "        orderData = responseData;\r",
                      "    }\r",
                      "\r",
                      "    // Evaluate the matched structural data layer against the correct field 'state'\r",
                      "    if (orderData && orderData.state) {\r",
                      "        console.log(\"Successfully extracted Order State:\", orderData.state);\r",
                      "        pm.expect(orderData.state.toUpperCase()).to.eql(\"OPEN\");\r",
                      "    } else {\r",
                      "        pm.expect.fail(\"Property Missing: Unable to locate 'state' field in any response schema format.\");\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response time is within acceptable threshold\", function () {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "GET",
                "header": [],
                "url": {
                  "raw": "https://connect.squareupsandbox.com/v2/orders/{{savedOrderId}}",
                  "protocol": "https",
