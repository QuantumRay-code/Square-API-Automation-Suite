          "name": "Data Integrity & Operational Boundaries",
          "item": [
            {
              "name": "Decline Exception Handling",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const responseData = pm.response.json();\r",
                      "\r",
                      "// HTTP Layer Check\r",
                      "pm.test(\"Status code is 400 Bad Request\", function () {\r",
                      "    pm.response.to.have.status(400);\r",
                      "});\r",
                      "\r",
                      "// Exact Field Value Rejection Check\r",
                      "pm.test(\"Verify explicit decline error metadata values\", function () {\r",
                      "    pm.expect(responseData.errors[0].category).to.eql(\"INVALID_REQUEST_ERROR\");\r",
                      "    pm.expect(responseData.errors[0].code).to.eql(\"VALUE_EMPTY\");\r",
                      "});\r",
                      "\r",
                      "// Structural Blueprint Contract Validation\r",
                      "// define an absolute draft schema checking data type constraints\r",
                      "const errorContractSchema = {\r",
                      "    \"type\": \"object\",\r",
                      "    \"required\": [\"errors\"],\r",
                      "    \"properties\": {\r",
                      "        \"errors\": {\r",
                      "            \"type\": \"array\",\r",
                      "            \"minItems\": 1,\r",
                      "            \"items\": {\r",
                      "                \"type\": \"object\",\r",
                      "                \"required\": [\"category\", \"code\", \"detail\"],\r",
                      "                \"properties\": {\r",
                      "                    \"category\": { \"type\": \"string\" },\r",
                      "                    \"code\": { \"type\": \"string\" },\r",
                      "                    \"detail\": { \"type\": \"string\" },\r",
                      "                    \"field\": { \"type\": \"string\" }\r",
                      "                }\r",
                      "            }\r",
                      "        }\r",
                      "    }\r",
                      "};\r",
                      "\r",
                      "// Use Postman's built-in tv4 validator to ensure every key matches its typed layout\r",
                      "pm.test(\"Enforce Enterprise Schema Structural Contract Alignment\", function () {\r",
                      "    const isContractValid = tv4.validate(responseData, errorContractSchema);\r",
                      "    pm.expect(isContractValid).to.be.true;\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response time is within acceptable threshold\", function () {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
