              "name": "Volatility Boundary Check",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Parse the structural validation error response payload\r",
                      "const responseData = pm.response.json();\r",
                      "\r",
                      "// Validate that the gateway correctly blocked the stale version write\r",
                      "pm.test(\"Status code is 400 or 409\", function () {\r",
                      "    pm.expect(pm.response.code).to.be.oneOf([400, 409]);\r",
                      "});\r",
                      "\r",
                      "// Concurrency Collision Verification\r",
                      "pm.test(\"Verify optimistic concurrency control constraints\", function () {\r",
                      "    if (responseData && responseData.errors && responseData.errors.length > 0) {\r",
                      "        const primaryError = responseData.errors[0];\r",
                      "        console.log(\"Captured Concurrency Rejection Category:\", primaryError.category);\r",
                      "        console.log(\"Captured Concurrency Rejection Code:\", primaryError.code);\r",
                      "\r",
                      "        // Expect standard validation error structures or version conflict parameters\r",
                      "        pm.expect(primaryError.category).to.be.oneOf([\"INVALID_REQUEST_ERROR\", \"CONFLICT_ERROR\"]);\r",
                      "        \r",
                      "        // Safety net text check confirming versioning control logic intervened\r",
                      "        const rawPayloadString = JSON.stringify(responseData).toLowerCase();\r",
                      "        const hasVersionContext = rawPayloadString.includes(\"version\") || rawPayloadString.includes(\"conflict\") || rawPayloadString.includes(\"expected\");\r",
                      "        pm.expect(hasVersionContext).to.be.true;\r",
                      "    } else {\r",
                      "        pm.expect.fail(\"Data Integrity Risk: The backend accepted an obsolete version snapshot update without safety validation checks.\");\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response time is within acceptable threshold\", function () {\r",
