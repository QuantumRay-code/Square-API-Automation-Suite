        {
          "name": "Gateway Security & Compliance",
          "item": [
            {
              "name": "Unauthorized Access Invalidation",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Parse the security error payload returned by the gateway\r",
                      "const responseData = pm.response.json();\r",
                      "\r",
                      "// Assertion: Validate that the security layer blocked the request immediately\r",
                      "pm.test(\"Status code is 401 Unauthorized\", function () {\r",
                      "    pm.response.to.have.status(401);\r",
                      "});\r",
                      "\r",
                      "// Security Schema Verification\r",
                      "pm.test(\"Verify explicit authentication rejection metadata\", function () {\r",
                      "    if (responseData && responseData.errors && responseData.errors.length > 0) {\r",
                      "        const primaryError = responseData.errors[0];\r",
                      "        console.log(\"Captured Security Exception Category:\", primaryError.category);\r",
