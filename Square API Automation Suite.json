            {
              "name": "Refund Balance Limit Check",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Parse the incoming idempotent response payload\r",
                      "const responseData = pm.response.json();\r",
                      "\r",
                      "// Square returns the cached successful status code for matching idempotency keys\r",
                      "pm.test(\"Status code is 200 or 201 (Idempotent Replay)\", function () {\r",
                      "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                      "});\r",
                      "\r",
                      "// Verify double-refund protection logic via status mapping\r",
                      "pm.test(\"Verify double-refund protection logic\", function () {\r",
                      "    const refundData = responseData.refund || responseData;\r",
                      "\r",
                      "    pm.expect(refundData).to.be.an('object');\r",
                      "    \r",
                      "    // Check if the response contains a valid payment/refund tracking ID\r",
                      "    pm.expect(refundData.id).to.exist;\r",
                      "    \r",
                      "    // Ensure the transaction is in a safe, processed state (not double-charged or stuck)\r",
                      "    pm.expect(refundData.status.toUpperCase()).to.be.oneOf([\"PENDING\", \"COMPLETED\", \"SUCCESS\"]);\r",
                      "    \r",
                      "    console.log(\"Idempotency Replay Verified: Server safely replayed transaction ID:\", refundData.id);\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response time is within acceptable threshold\", function () {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
