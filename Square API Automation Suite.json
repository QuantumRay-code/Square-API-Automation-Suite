            {
              "name": "Execute Refund Request",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Parse the incoming server response payload\r",
                      "const responseData = pm.response.json();\r",
                      "\r",
                      "const isCleanSuccess = pm.response.code === 200 || pm.response.code === 201;\r",
                      "const isUpstreamCanceledBlock = pm.response.code === 400 && responseData.errors;\r",
                      "\r",
                      "// Track remaining refundable balance so the next request (Refund Balance Limit Check)\r",
                      "// requests a valid amount instead of exceeding what is left.\r",
                      "const currentTotal = pm.environment.get(\"currentOrderTotal\");\r",
                      "if (currentTotal !== undefined) {\r",
                      "    const remaining = parseInt(currentTotal) - 500;\r",
                      "    pm.environment.set(\"remainingRefundableAmount\", remaining);\r",
                      "    console.log(\"Remaining refundable balance after this refund:\", remaining);\r",
                      "}\r",
                      "\r",
                      "pm.test(\"Status code validation layer\", function () {\r",
                      "    if (isCleanSuccess) {\r",
                      "        pm.response.to.have.status(200);\r",
                      "    } else if (isUpstreamCanceledBlock) {\r",
                      "        console.log(\"Portfolio Log: Handled upstream transaction cancellation safely.\");\r",
                      "        pm.expect(pm.response.code).to.equal(400);\r",
                      "    } else {\r",
                      "        pm.expect.fail(`Unexpected ledger status received: ${pm.response.code}`);\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "// Multi-State Refund Validation\r",
                      "pm.test(\"Verify refund processing state\", function () {\r",
                      "    const refundData = responseData.refund || responseData;\r",
                      "\r",
                      "    if (refundData && refundData.status) {\r",
                      "        console.log(\"Captured Refund Status from gateway:\", refundData.status);\r",
                      "        const normalizedStatus = refundData.status.toUpperCase();\r",
                      "        const isValidState = [\"PENDING\", \"COMPLETED\", \"REJECTED\"].includes(normalizedStatus);\r",
                      "        pm.expect(isValidState).to.be.true;\r",
                      "\r",
                      "        pm.environment.set(\"savedRefundId\", refundData.id);\r",
                      "    } else if (isUpstreamCanceledBlock) {\r",
                      "        console.log(\"Verified sandbox edge constraint: \" + responseData.errors[0].detail);\r",
                      "        pm.expect(responseData.errors[0].code).to.be.a('string');\r",
                      "    } else {\r",
                      "        pm.expect.fail(\"Property Evaluation Failed: Missing response validation metrics.\");\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response time is within acceptable threshold\", function () {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
