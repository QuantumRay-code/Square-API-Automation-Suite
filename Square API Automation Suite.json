            {
              "name": "Capture Payment Gateway",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Parse the incoming payment transaction payload\r",
                      "const responseData = pm.response.json();\r",
                      "\r",
                      "// Assertion 1: Verify the payment request was accepted successfully\r",
                      "pm.test(\"Status code is 200 or 201\", function () {\r",
                      "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
                      "});\r",
                      "\r",
                      "// Assertion 2: Verify the payment completed successfully without cancellation\r",
                      "pm.test(\"Verify payment is successfully COMPLETED\", function () {\r",
                      "    const paymentData = responseData.payment;\r",
                      "\r",
                      "    if (paymentData && paymentData.status) {\r",
                      "        console.log(\"Captured Payment Status from gateway:\", paymentData.status);\r",
                      "        \r",
                      "        // Ensure the payment went through cleanly\r",
                      "        pm.expect(paymentData.status.toUpperCase()).to.be.oneOf([\"COMPLETED\", \"APPROVED\"]);\r",
                      "\r",
                      "        // Save the Payment ID for the refund step (Request 5)\r",
                      "        pm.environment.set(\"savedPaymentId\", paymentData.id);\r",
                      "        console.log(\"Cached Payment ID for Downstream Refund:\", paymentData.id);\r",
                      "    } else {\r",
                      "        pm.expect.fail(\"Property Evaluation Failed: 'payment' object or status missing from response.\");\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response time is within acceptable threshold\", function () {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
