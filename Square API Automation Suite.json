                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n  \"idempotency_key\": \"{{$guid}}\",\r\n  \"amount_money\": {\r\n    \"amount\": {{currentOrderTotal}},\r\n    \"currency\": \"USD\"\r\n  },\r\n  \"source_id\": \"cnon:card-nonce-ok\",\r\n  \"order_id\": \"{{savedOrderId}}\"\r\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
