            {
              "name": "Modify Order Records",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Parse the incoming structural transaction payload response\r",
                      "const responseData = pm.response.json();\r",
                      "\r",
                      "// Assertion 1: Confirm that the data modification was accepted by the server\r",
                      "pm.test(\"Status code is 200\", function () {\r",
                      "    pm.response.to.have.status(200);\r",
                      "});\r",
                      "\r",
                      "// Assertion 2: Advanced Strategy - Production Schema & State Mutation Validation\r",
                      "pm.test(\"Verify record modification details\", function () {\r",
                      "    const orderData = responseData.order || responseData;\r",
                      "\r",
                      "    if (orderData) {\r",
                      "        // Save the new version back into the same variable for downstream requests\r",
                      "        if (orderData.version !== undefined) {\r",
                      "            pm.environment.set(\"currentOrderVersion\", orderData.version);\r",
                      "            console.log(\"Synchronized New Order Version State:\", orderData.version);\r",
                      "        }\r",
                      "\r",
                      "        if (orderData.line_items && orderData.line_items.length > 0) {\r",
                      "            const itemDescription = orderData.line_items[0].name;\r",
                      "            pm.expect(itemDescription).to.be.a('string');\r",
                      "            console.log(\"Successfully verified committed line item name:\", itemDescription);\r",
                      "        }\r",
                      "\r",
                      "        // Capture the real order total so downstream payment/refund requests\r",
                      "        // can reference the correct amount instead of a hardcoded value.\r",
                      "        if (orderData.total_money && orderData.total_money.amount !== undefined) {\r",
                      "            pm.environment.set(\"currentOrderTotal\", orderData.total_money.amount);\r",
                      "            console.log(\"Captured order total for this iteration:\", orderData.total_money.amount);\r",
                      "        }\r",
                      "\r",
                      "    } else {\r",
                      "        pm.expect.fail(\"Property Evaluation Failed: Response body does not contain valid transaction metadata.\");\r",
                      "    }\r",
                      "});\r",
                      "\r",
                      "pm.test(\"Response time is within acceptable threshold\", function () {\r",
                      "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "PUT",
                "header": [],
                "body": {
